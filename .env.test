# Тестовые переменные окружения для E2E тестов
# Для локального запуска тестов используем localhost (порты проброшены из Docker)
# Внутри контейнеров Docker Compose автоматически резолвит имена сервисов
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_password_ci_2024
POSTGRES_DB=wednesdaydb_test
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

SCHEDULER_SEND_TIMES=09:00,12:00,18:00
SCHEDULER_WEDNESDAY_DAY=2
SCHEDULER_TZ=Europe/Moscow

TESTING=1
