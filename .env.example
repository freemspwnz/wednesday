# ===== Environment =====
ENV=DEV
VERSION=7.0.0

# ===== Logging =====
LOGGING__FILE_PATH=/var/tmp/logs/wednesday.log
LOGGING__LEVEL=INFO
LOGGING__TO_FILE=False

# ===== Telegram =====
TELEGRAM__ADMIN_ID=your_telegram_user_id_here
TELEGRAM__BOT_TOKEN=your_telegram_token_here

# ===== Postgres =====
POSTGRES__DB_NAME=your_postgres_db_name_here
POSTGRES__HOST=postgres
POSTGRES__PASSWORD=your_postgres_password_here
POSTGRES__PORT=5432
POSTGRES__USER=your_postgres_user_here

# ===== Redis =====
REDIS__HOST=redis
REDIS__PASSWORD=your_redis_password_here
REDIS__PORT=6379

# ===== Retry =====
RETRY__ATTEMPTS=3
RETRY__EXP_BASE=2.0
RETRY__INITIAL=2.0
RETRY__JITTER=1.0
RETRY__MAX=30.0
RETRY__RERAISE=True

# ===== Scheduler =====
SCHEDULER__SEND_TIMES=09:00,12:00,18:00
SCHEDULER__TZ=Europe/Moscow
SCHEDULER__WEDNESDAY_DAY=2

# ===== Gigachat =====

# Authorization key для GigaChat API (Base64 encoded)
# Получите на https://developers.sber.ru/ (нужна регистрация)
GIGACHAT_AUTH_KEY=your_auth_key_here

# URL для аутентификации GigaChat (опционально, по умолчанию используется стандартный)
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth

# URL для API запросов GigaChat (опционально, по умолчанию используется стандартный)
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions

# Scope для аутентификации (опционально, по умолчанию: GIGACHAT_API_PERS)
GIGACHAT_SCOPE=

# Путь к файлу сертификата для GigaChat API (опционально)
# Если указан, будет использоваться этот сертификат вместо стандартных
# Пример: certs/russiantrustedca.pem или /путь/к/сертификату.pem
# Приоритет: если указан GIGACHAT_CERT_PATH, он используется; иначе проверяется GIGACHAT_VERIFY_SSL
GIGACHAT_CERT_PATH=certs/russiantrustedca.pem

# Проверять SSL сертификаты для GigaChat (опционально, по умолчанию: true)
# Используется только если GIGACHAT_CERT_PATH не указан
# Установите false если есть проблемы с сертификатами и сертификат не указан
# ВНИМАНИЕ: Отключение проверки SSL снижает безопасность!
GIGACHAT_VERIFY_SSL=True

# ===== SENTRY =====

# DSN для интеграции с Sentry (Data Source Name)
# Получите на https://sentry.io/ после создания проекта
# SENTRY_DSN=https://ea4f105e9360e0b3acd54ce9dd4412e8@o4510471955939328.ingest.de.sentry.io/4510471960395856

# Название окружения для Sentry (опционально)
# SENTRY_ENVIRONMENT=DEV

# Версия релиза для Sentry (опционально)
# RELEASE=

# ==========================================
# ПРИМЕЧАНИЯ
# ==========================================
# - Никогда не коммитьте файл .env в Git
# - Проверьте права доступа к файлу .env (chmod 600 .env)
# - После изменения .env перезапустите бота
# - Используйте кавычки если в значениях есть пробелы
# ==========================================
