# Тестовые переменные окружения для E2E тестов
# Для локального запуска тестов используем localhost (порты проброшены из Docker)
# Внутри контейнеров Docker Compose автоматически резолвит имена сервисов

# PostgreSQL
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_password_ci_2024
POSTGRES_DB=wednesdaydb_test
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TEST_REDIS_URL=

# Telegram
TELEGRAM_BOT_TOKEN=test-token
CHAT_ID=12345
ADMIN_CHAT_ID=54321

# Kandinsky
KANDINSKY_API_KEY=test-api
KANDINSKY_SECRET_KEY=test-secret

# GigaChat
GIGACHAT_AUTHORIZATION_KEY=ZmFrZS1rZXk=

# Scheduler
SCHEDULER_SEND_TIMES=09:00,12:00,18:00
SCHEDULER_WEDNESDAY_DAY=2
SCHEDULER_TZ=Europe/Moscow
TZ=Europe/Moscow

# Model backends
IMAGE_MODEL_BACKEND=kandinsky
TEXT_MODEL_BACKEND=gigachat

# Monitoring
PROMETHEUS_EXPORTER_PORT=8000
HEALTHCHECK_PORT=8080

# Testing
TESTING=1
